ZENDESK_SUBDOMAIN=bankingbridgesupport
PORT=3001

# Required for GET /cron/stale-articles (Vercel Cron auth — see vercel.json's crons entry)
CRON_SECRET=
# Slack channel id to post the weekly stale-article digest to
SLACK_NOTIFY_CHANNEL=
# Optional, default 180 — articles not updated in this many days are flagged as stale
STALE_ARTICLE_DAYS=180
